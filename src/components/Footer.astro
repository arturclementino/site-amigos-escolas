---
// src/components/Footer.astro
---
<footer class="bg-forest-950 py-14 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="grid md:grid-cols-3 gap-10 pb-10 border-b border-white/10">
      <div>
        <p class="font-display text-white font-bold text-xl mb-2">AAEGB</p>
        <p class="text-white/40 text-xs font-light mb-4">Amigos das Escolas de Guiné-Bissau</p>
        <p class="text-white/30 text-xs leading-relaxed font-light">
          Setor de Cacine · Região de Tombali<br/>Sul da Guiné-Bissau · Desde 2009
        </p>
      </div>

      <div>
        <p class="text-xs font-bold text-white/40 uppercase tracking-widest mb-4">Navegação</p>
        <nav class="flex flex-col gap-2 text-xs text-white/40 font-medium">
          <a href="/" class="hover:text-white/70 transition-colors">Início</a>
          <a href="/projetos" class="hover:text-white/70 transition-colors">Projetos</a>
          <a href="/quem-somos" class="hover:text-white/70 transition-colors">Quem Somos</a>
          <a href="/voluntariado" class="hover:text-white/70 transition-colors">Voluntariado</a>
          <a href="/contato" class="hover:text-white/70 transition-colors">Contato</a>
        </nav>
      </div>

      <div>
        <p class="text-xs font-bold text-white/40 uppercase tracking-widest mb-4">Projetos</p>
        <nav class="flex flex-col gap-2 text-xs text-white/40 font-medium">
          <a href="/projetos#escola" class="hover:text-white/70 transition-colors">Escola Betel</a>
          <a href="/projetos#internato" class="hover:text-white/70 transition-colors">Casa do Estudante</a>
          <a href="/projetos#radio" class="hover:text-white/70 transition-colors">Rádio Voz de Paz FM</a>
          <a href="/projetos#agua" class="hover:text-white/70 transition-colors">Projeto Água Potável</a>
          <a href="/projetos#biblioteca" class="hover:text-white/70 transition-colors">Biblioteca & Digital</a>
          <a href="/projetos#ginasio" class="hover:text-saffron transition-colors">Ginásio Poliesportivo ✦</a>
        </nav>
      </div>
    </div>

    <div class="flex flex-col md:flex-row justify-between items-center gap-4 pt-8">
      <p class="text-white/20 text-xs">&copy; 2026 AAEGB · Todos os direitos reservados</p>
      <a href="/doar" class="text-xs font-black text-saffron uppercase tracking-widest hover:opacity-80 transition-colors">
        Fazer uma Doação →
      </a>
    </div>
  </div>
</footer>
