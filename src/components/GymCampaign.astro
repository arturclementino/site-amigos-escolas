<section class="py-24 bg-forest-900">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <div>
        <span class="inline-block bg-ember text-white text-xs font-black uppercase tracking-widest px-4 py-1.5 rounded-full mb-6">Campanha em Andamento</span>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-white leading-tight mb-6">
          Ajude a construir o Ginásio Poliesportivo de Cacine.
        </h2>
        <p class="text-white/60 font-light leading-relaxed mb-8">
          Para muitos jovens do setor de Cacine, as ruas são a única opção de lazer...
        </p>
      </div>

      <div class="space-y-4">
        <a href="/doar" class="flex items-center justify-between bg-ember hover:opacity-90 text-white font-bold py-5 px-8 rounded-2xl transition-all group">
          <span>Quero apoiar o ginásio</span>
          <span class="text-xl group-hover:translate-x-1 transition-transform">→</span>
        </a>
        <a href="/contato" class="flex items-center justify-between bg-white/10 hover:bg-white/15 text-white font-bold py-5 px-8 rounded-2xl transition-all border border-white/10 group">
          <span>Parceria institucional</span>
          <span class="text-xl group-hover:translate-x-1 transition-transform">→</span>
        </a>
      </div>
    </div>
  </div>
</section>
