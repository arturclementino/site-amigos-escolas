---
// src/components/ImpactStats.astro
---
<section class="py-24 bg-[#EDE8DC]">
  <div class="max-w-7xl mx-auto px-6">
    <p class="text-xs font-bold text-ember tracking-[0.3em] uppercase mb-14">Impacto Real em Números</p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 md:gap-0 md:divide-x divide-slate-300/50">
      <div class="md:pr-10">
        <p class="font-display text-6xl md:text-7xl font-bold text-forest-900 tracking-tight leading-none">15.000+</p>
        <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mt-3">Alunos Matriculados</p>
        <p class="text-xs text-slate-400 mt-1 font-light">Escola Betel e extensões</p>
      </div>
      <div class="md:px-10">
        <p class="font-display text-6xl md:text-7xl font-bold text-forest-900 tracking-tight leading-none">+ 91</p>
        <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mt-3">Tabancas Alcançadas</p>
        <p class="text-xs text-slate-400 mt-1 font-light">aldeias na floresta profunda</p>
      </div>
      <div class="md:px-10">
        <p class="font-display text-6xl md:text-7xl font-bold text-forest-900 tracking-tight leading-none">15+</p>
        <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mt-3">Anos de Atuação</p>
        <p class="text-xs text-slate-400 mt-1 font-light">presença contínua desde 2009</p>
      </div>
      <div class="md:pl-10">
        <p class="font-display text-6xl md:text-7xl font-bold text-forest-900 tracking-tight leading-none">1.000+</p>
        <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mt-3">Famílias Assistidas</p>
        <p class="text-xs text-slate-400 mt-1 font-light">no setor de Cacine</p>
      </div>
    </div>
  </div>
</section>
