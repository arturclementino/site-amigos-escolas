---
// src/components/ImpactStats.astro
---
<section class="py-20 sm:py-24 bg-[#EDE8DC]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <p class="text-xs font-bold text-ember tracking-[0.3em] uppercase mb-12">Impacto Real em Números</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6">
      <div class="rounded-[1.75rem] bg-white p-8 shadow-sm ring-1 ring-slate-200/70">
        <p class="font-display text-5xl sm:text-6xl font-black text-forest-900 tracking-tight leading-none">15.000+</p>
        <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mt-5">Alunos Matriculados</p>
        <p class="text-sm text-slate-400 mt-3 leading-relaxed">Escola Betel e extensões</p>
      </div>
      <div class="rounded-[1.75rem] bg-white p-8 shadow-sm ring-1 ring-slate-200/70">
        <p class="font-display text-5xl sm:text-6xl font-black text-forest-900 tracking-tight leading-none">91+</p>
        <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mt-5">Tabancas Alcançadas</p>
        <p class="text-sm text-slate-400 mt-3 leading-relaxed">Aldeias na floresta profunda</p>
      </div>
      <div class="rounded-[1.75rem] bg-white p-8 shadow-sm ring-1 ring-slate-200/70">
        <p class="font-display text-5xl sm:text-6xl font-black text-forest-900 tracking-tight leading-none">15+</p>
        <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mt-5">Anos de Atuação</p>
        <p class="text-sm text-slate-400 mt-3 leading-relaxed">Presença contínua desde 2009</p>
      </div>
      <div class="rounded-[1.75rem] bg-white p-8 shadow-sm ring-1 ring-slate-200/70">
        <p class="font-display text-5xl sm:text-6xl font-black text-forest-900 tracking-tight leading-none">1.000+</p>
        <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mt-5">Famílias Assistidas</p>
        <p class="text-sm text-slate-400 mt-3 leading-relaxed">No setor de Cacine</p>
      </div>
    </div>
  </div>
</section>
