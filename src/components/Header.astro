---
// src/components/Header.astro
---
<header class="absolute w-full z-50 px-6 py-6 md:px-12">
  <div class="max-w-7xl mx-auto flex justify-between items-center">
    <img src="/logo.jpg" alt="AAEGB" class="h-12 w-auto object-contain" onerror="this.style.display='none'" />
    
    <nav class="hidden md:flex items-center gap-9 text-white/75 text-xs font-bold tracking-widest uppercase">
      <a href="/" class="text-white border-b border-saffron pb-0.5">Início</a>
      <a href="/projetos" class="hover:text-saffron transition-colors">Projetos</a>
      <a href="/quem-somos" class="hover:text-saffron transition-colors">Quem Somos</a>
      <a href="/voluntariado" class="hover:text-saffron transition-colors">Voluntariado</a>
    </nav>

    <a href="/doar" class="bg-saffron hover:opacity-90 text-forest-950 text-xs font-black py-3 px-7 rounded-full transition-all uppercase tracking-widest shadow-lg">
      Apoiar
    </a>
  </div>
</header>
