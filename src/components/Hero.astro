---
// src/components/Hero.astro
---

<section class="relative min-h-screen flex items-center px-6 overflow-hidden bg-[#0F2E1F]">

  <div class="absolute inset-0 z-0">
    <img src="/images/capa-hero.JPG"
     alt="Dia das Crianças na Escola Betel" 
     class="w-full h-full object-cover filter saturate-[0.2] brightness-[0.65]" />
    <div class="absolute inset-0 bg-gradient-to-t from-[#0F2E1F] via-[#0F2E1F]/60 to-[#0F2E1F]/30"></div>
  </div>

  <div class="absolute right-0 top-1/2 -translate-y-1/2 z-0 pointer-events-none select-none overflow-hidden">
    <span class="font-['Playfair_Display'] font-black text-white/[0.03] leading-none"
          style="font-size:clamp(220px,36vw,560px);line-height:0.85">15K</span>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto w-full pt-28 pb-20">

    <div class="flex items-center gap-3 mb-8">
      <span class="block w-8 h-px bg-[#E8A020]"></span>
      <span class="text-[#E8A020] font-bold tracking-[0.22em] uppercase text-xs">
        Cacine · Guiné-Bissau · Desde 2009
      </span>
    </div>

    <h1 class="font-['Playfair_Display'] leading-[1.05] tracking-tight mb-8">
      <span class="block text-white font-bold italic"
            style="font-size:clamp(2.2rem,6vw,5rem)">A educação é a semente.</span>
      <span class="block text-[#E8A020] font-bold"
            style="font-size:clamp(2.2rem,6vw,5rem)">O futuro é a colheita.</span>
    </h1>

    <p class="text-base md:text-lg text-white/65 font-light leading-relaxed mb-10 max-w-xl">
      Há 15 anos transformamos o Sul da Guiné-Bissau com educação, moradia, água potável
      e tecnologia — para que o <strong class="text-white font-semibold">Povo Nalu </strong>
      e comunidades vizinhas construam o próprio futuro.
    </p>

    <div class="flex flex-col sm:flex-row gap-3">
      <a href="/doar"
         class="inline-flex items-center justify-center bg-[#C44B1D] hover:bg-[#D35400]
                text-white font-bold py-4 px-9 rounded-full text-sm transition-all tracking-wide shadow-xl">
        Financiar um Projeto
      </a>
      <a href="#projetos"
         class="inline-flex items-center justify-center bg-white/10 hover:bg-white/20
                text-white border border-white/20 font-semibold py-4 px-9 rounded-full
                text-sm transition-all">
        Ver Nossos Projetos &rarr;
      </a>
    </div>

    <div class="flex flex-wrap gap-8 mt-16 pt-10 border-t border-white/10">
      <div>
        <p class="font-['Playfair_Display'] text-3xl font-bold text-white">15.000+</p>
        <p class="text-xs text-white/40 uppercase tracking-widest mt-0.5">Alunos</p>
      </div>
      <div>
        <p class="font-['Playfair_Display'] text-3xl font-bold text-white">91+</p>
        <p class="text-xs text-white/40 uppercase tracking-widest mt-0.5">Tabancas</p>
      </div>
      <div>
        <p class="font-['Playfair_Display'] text-3xl font-bold text-white">15+</p>
        <p class="text-xs text-white/40 uppercase tracking-widest mt-0.5">Anos</p>
      </div>
      <div>
        <p class="font-['Playfair_Display'] text-3xl font-bold text-white">1.000+</p>
        <p class="text-xs text-white/40 uppercase tracking-widest mt-0.5">Famílias</p>
      </div>
    </div>

  </div>
</section>