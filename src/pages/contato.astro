---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Contato | AAEGB" description="Entre em contato com a AAEGB para doaçőes, parcerias e voluntariado.">
  <Header />

  <main class="bg-[#F7F5F0]">
    <section class="bg-white py-24">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] items-start">
          <div>
            <p class="text-xs font-bold text-ember uppercase tracking-[0.35em] mb-4">Contato</p>
            <h1 class="font-display text-4xl sm:text-5xl font-bold text-forest-900 leading-tight">Fale conosco para apoiar e conhecer nossos projetos.</h1>
            <p class="mt-6 text-slate-600 leading-relaxed text-lg">Estamos disponíveis para receber dúvidas, propostas de parceria e solicitaçőes de voluntariado. Sua mensagem é o primeiro passo para transformar realidades.</p>
          </div>
          <div class="rounded-[2rem] border border-slate-200 bg-slate-50 p-8 shadow-sm">
            <p class="text-xs uppercase tracking-[0.35em] text-saffron font-black mb-4">Informaçőes</p>
            <div class="space-y-4 text-sm text-slate-700 leading-relaxed">
              <p><strong>Email:</strong> contato@aaegb.org</p>
              <p><strong>Local:</strong> Cacine, Regiăo de Tombali, Guiné-Bissau</p>
              <p><strong>Tel:</strong> +244 123 456 789</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 py-20">
      <div class="rounded-[1.75rem] border border-slate-200 bg-white p-10 shadow-sm">
        <p class="text-xs uppercase tracking-[0.35em] text-ember font-black mb-4">Envie sua mensagem</p>
        <form class="grid gap-6">
          <div class="grid gap-6 lg:grid-cols-2">
            <input type="text" placeholder="Seu nome" class="w-full rounded-3xl border border-slate-200 bg-slate-50 px-5 py-4 text-sm text-slate-900 outline-none focus:border-forest-900 focus:ring-2 focus:ring-forest-900/10" />
            <input type="email" placeholder="Seu email" class="w-full rounded-3xl border border-slate-200 bg-slate-50 px-5 py-4 text-sm text-slate-900 outline-none focus:border-forest-900 focus:ring-2 focus:ring-forest-900/10" />
          </div>
          <textarea rows="6" placeholder="Como podemos ajudar?" class="w-full rounded-3xl border border-slate-200 bg-slate-50 px-5 py-4 text-sm text-slate-900 outline-none focus:border-forest-900 focus:ring-2 focus:ring-forest-900/10"></textarea>
          <button type="submit" class="inline-flex items-center justify-center rounded-full bg-forest-900 px-6 py-3 text-sm font-bold uppercase tracking-[0.25em] text-white hover:bg-forest-800 transition">Enviar mensagem</button>
        </form>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
