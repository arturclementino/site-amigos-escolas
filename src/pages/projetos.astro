---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const projects = [
  {
    icon: "??",
    label: "Escola Betel",
    title: "Ensino integral de pré-escolar ao 12.ş ano",
    description: "Apoiamos 770 alunos com educaçăo, alimentaçăo e suporte social no coraçăo de Cacine.",
  },
  {
    icon: "??",
    label: "Casa do Estudante",
    title: "Internato para jovens de tabancas distantes",
    description: "Acolhimento seguro, alimentaçăo e preparaçăo acadęmica para quem precisa estudar longe de casa.",
  },
  {
    icon: "??",
    label: "Rádio FM",
    title: "Voz comunitária 107.0 MHz",
    description: "Transmissőes de saúde, educaçăo e cultura que alcançam aldeias isoladas e fortalecem a cidadania local.",
  },
  {
    icon: "??",
    label: "Água Potável",
    title: "Poços sustentáveis e manutençăo local",
    description: "Acesso ŕ água limpa reduz doenças e oferece autonomia ŕs famílias do setor de Cacine.",
  },
  {
    icon: "??",
    label: "Biblioteca & TIC",
    title: "Leitura e inclusăo digital",
    description: "Biblioteca e laboratório promovem formaçăo, pesquisa e acesso a oportunidades para jovens.",
  },
  {
    icon: "?",
    label: "Ginásio",
    title: "Complexo poliesportivo em construçăo",
    description: "Espaço para esporte, saúde e integraçăo social, com foco na juventude local.",
  },
];
---

<Layout title="Projetos | AAEGB" description="Conheça os projetos sociais, educacionais e comunitários que transformam Cacine.">
  <Header />

  <main>
    <section class="relative overflow-hidden bg-forest-900 pb-20 pt-28 text-white">
      <div class="absolute inset-x-0 top-0 h-72 bg-[radial-gradient(circle_at_top_left,_rgba(232,160,32,0.18),_transparent_35%)]"></div>
      <div class="max-w-6xl mx-auto px-4 sm:px-6 relative">
        <div class="grid gap-10 lg:grid-cols-[1.3fr_0.9fr] items-center">
          <div class="max-w-2xl">
            <p class="text-xs font-bold text-saffron uppercase tracking-[0.35em] mb-4">Nossos Projetos</p>
            <h1 class="font-display text-4xl sm:text-5xl font-bold leading-tight">Transformaçăo local com educaçăo, infraestrutura e inclusăo.</h1>
            <p class="mt-6 max-w-2xl text-white/80 leading-relaxed text-lg">
              Cada projeto foi pensado para gerar impacto real e sustentável no setor de Cacine, conectando famílias, escolas e juventude a oportunidades duradouras.
            </p>
            <div class="mt-10 flex flex-col gap-3 sm:flex-row sm:items-center">
              <a href="/doar" class="inline-flex items-center justify-center rounded-full bg-ember px-6 py-3 text-sm font-bold uppercase tracking-[0.25em] text-white shadow-xl hover:opacity-95 transition">Apoiar um projeto</a>
              <a href="#projetos-list" class="inline-flex items-center justify-center rounded-full border border-white/20 bg-white/10 px-6 py-3 text-sm font-semibold uppercase tracking-[0.25em] text-white hover:bg-white/15 transition">Ver detalhes</a>
            </div>
          </div>
          <div class="rounded-[2rem] border border-white/10 bg-white/10 p-8 shadow-2xl backdrop-blur-xl">
            <p class="text-xs uppercase tracking-[0.35em] text-saffron font-black mb-4">Destaques</p>
            <ul class="space-y-4 text-sm text-white/80 leading-relaxed">
              <li>Ensino completo para 770 alunos no coraçăo de Cacine.</li>
              <li>Internato que acolhe jovens de aldeias distantes.</li>
              <li>Rádio comunitária com educaçăo e saúde em cada trecho.</li>
              <li>Poços que transformam água limpa em dignidade.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section id="projetos-list" class="max-w-7xl mx-auto px-4 sm:px-6 py-20">
      <div class="grid gap-8 xl:grid-cols-3">
        {projects.map((project) => (
          <article class="rounded-[1.75rem] border border-slate-200 bg-white p-7 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl">
            <div class="flex h-12 w-12 items-center justify-center rounded-3xl bg-forest-900 text-saffron text-xl mb-5">{project.icon}</div>
            <p class="text-[10px] font-black uppercase tracking-[0.35em] text-ember mb-3">{project.label}</p>
            <h2 class="font-display text-2xl font-bold text-forest-900 mb-4">{project.title}</h2>
            <p class="text-sm text-slate-600 leading-relaxed">{project.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="bg-[#F4F1EB] py-20 border-t border-slate-200">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
        <p class="text-xs font-bold text-ember uppercase tracking-[0.35em] mb-4">Prossiga conosco</p>
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-forest-900 leading-tight max-w-3xl mx-auto">
          Sua parceria ajuda a levar educaçăo, saúde e infraestrutura onde eles fazem diferença real.
        </h2>
        <div class="mt-10 flex flex-col sm:flex-row justify-center gap-4">
          <a href="/doar" class="inline-flex items-center justify-center rounded-full bg-ember px-6 py-3 text-sm font-bold uppercase tracking-[0.25em] text-white shadow-xl hover:opacity-95 transition">Contribuir agora</a>
          <a href="/contato" class="inline-flex items-center justify-center rounded-full border border-forest-900 px-6 py-3 text-sm font-semibold uppercase tracking-[0.25em] text-forest-900 hover:bg-forest-900/5 transition">Falar com a equipe</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
